# Вводим размер массива
N = int(input("Введите количество элементов: "))

# Вводим элементы массива через пробел и сохраняем их в список
A = list(map(int, input("Введите элементы массива через пробел: ").split()))

# Находим максимальный элемент массива
max_element = max(A)

# Находим минимальный элемент массива
min_element = min(A)

# Находим индекс максимального элемента
max_index = A.index(max_element)

# Находим индекс минимального элемента
min_index = A.index(min_element)

# Определяем левую и правую границы участка между ними
left = min(max_index, min_index)
right = max(max_index, min_index)

# Переменная для хранения суммы отрицательных элементов
sum_negative = 0

# Перебираем элементы между минимальным и максимальным
# +1 не нужно, потому что сами min и max не входят в диапазон
for i in range(left + 1, right):

    # Если элемент отрицательный
    if A[i] < 0:

        # Добавляем его к сумме
        sum_negative += A[i]

# Выводим результат
print("Сумма отрицательных элементов:", sum_negative)
